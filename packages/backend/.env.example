# ===== AI 分段（必填，没有时禁用 AI 功能） =====
# DeepSeek 控制台申请: https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ===== 小米 MiMo TTS v2.5（主引擎） =====
# 控制台: https://mimo.mi.com/
# v2.5 支持预设音色 / 音色设计 / 音色复刻三种模式
MIMO_API_KEY=
MIMO_BASE_URL=https://api.mimo.mi.com/v1

# ===== 备选：edge-tts 引擎（无需 key，免密） =====
# 微软 Edge 在线服务，免费但无音色设计/复刻能力
# 不需要配置任何 key，保留空即可启用

# ===== 服务端口 =====
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# ===== 调试 =====
NODE_ENV=development
LOG_LEVEL=info
